# --- Provider: self-hosted Ollama (primary) -------------------------------
# The pipeline talks to Ollama's OpenAI-compatible endpoint. These have
# working defaults baked into lib/llm.ts (localhost:11434/v1 + kimi-k2.6:cloud),
# so local dev needs no .env at all. Override here to point elsewhere — e.g.
# set OPENAI_COMPAT_URL to a cloudflared tunnel URL for a public deploy.
OPENAI_COMPAT_URL=http://localhost:11434/v1
OPENAI_COMPAT_KEY=ollama
OPENAI_COMPAT_MODEL=kimi-k2.6:cloud
# Optional second Ollama model tried if the primary call fails:
OPENAI_COMPAT_FALLBACK_MODEL=

# --- Provider: Anthropic (optional fallback) ------------------------------
# Only joins the provider chain if ANTHROPIC_API_KEY is set; otherwise skipped.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Native Ollama endpoint (only for embeddings / health) ----------------
# lib/llm.ts embed()/health() use Ollama's native /api surface. Leave unset
# unless you use embeddings.
OLLAMA_BASE_URL=
OLLAMA_EMBEDDING_MODEL=
