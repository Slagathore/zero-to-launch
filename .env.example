# Anthropic (primary + sole provider — see lib/claude.ts header)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Optional: local/cloud Ollama via an OpenAI-compatible endpoint. Leave unset
# in this project — providerChain() in lib/claude.ts skips this leg entirely
# when OPENAI_COMPAT_URL is empty, so Anthropic is used directly.
OPENAI_COMPAT_URL=
OPENAI_COMPAT_KEY=
OPENAI_COMPAT_MODEL=
OPENAI_COMPAT_FALLBACK_MODEL=
OLLAMA_BASE_URL=
OLLAMA_EMBEDDING_MODEL=
